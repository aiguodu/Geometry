server {
    server_name math.simawt.cn;
    root /var/www/math;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    # Unified TTS proxy path
    location /api/tts {
        proxy_pass http://127.0.0.1:5000/api/tts;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Legacy support for projects using /tts
    location /tts {
        proxy_pass http://127.0.0.1:5000/api/tts;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    listen 443 ssl;
    ssl_certificate /etc/letsencrypt/live/math.simawt.cn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/math.simawt.cn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
}

server {
    if ($host = math.simawt.cn) {
        return 301 https://$host$request_uri;
    }
    listen 80;
    server_name math.simawt.cn;
    return 404;
}
